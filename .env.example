SECRET_KEY=django-insecure-local-dev-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Optional. By default SQLite is stored at BASE_DIR / "db.sqlite3".
# DATABASE_URL=sqlite:////absolute/path/to/db.sqlite3

# Production security. For local HTTP development, keep these relaxed.
CSRF_TRUSTED_ORIGINS=
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Optional. Required for the public newsletter signup form to sync to Brevo.
BREVO_API_KEY=
BREVO_LIST_ID=

# Optional. Required for contact form notification emails.
CONTACT_NOTIFICATION_TO=
CONTACT_NOTIFICATION_FROM_EMAIL=
CONTACT_NOTIFICATION_FROM_NAME=Kent artiste
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=
